##[>] 🤖
#[what] root of the local gitlab workspace to clone into + index. default: ~/projects/gitlab
WORKSPACE_DIR=
#[what] gitlab group to clone (with subgroups); gates the gitlabGroup che profile (execIf). required, no default; unset -> clone/index skip
GITLAB_GROUP=konradodwrot
#[what] host dir under $WORKSPACE_DIR for that group's repos (replaces the remote group path segment). required, no default; unset -> clone skips
HOST_DIR_GITLAB_GROUP=konradodwrot
#[what] gitlab token for https clone (CI); unset -> clone script skips
GITLAB_TOKEN=
##[<] 🤖
